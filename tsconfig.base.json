{
  "compilerOptions": {
    "allowJs": true,
    "declaration": false,
    "baseUrl": "src",
    "outDir": "dist",
    "paths": {
      "*": [
        "src/*"
      ]
    },
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    // Explicitly false: TypeScript 6 changed the default from false to
    // true. Preserving prior behavior here deliberately — this codebase
    // has never been checked against strict mode (strictNullChecks
    // especially). Adopting strict mode is a separate, planned future
    // effort, not bundled into the TS6 version upgrade itself.
    "strict":false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "removeComments": false,
    "preserveConstEnums": true,
    "skipLibCheck": true,
    "lib": [
      "es2017",
      "dom",
      "es2018",
      "es2019",
      "es2020"
    ],
    "module": "commonjs",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "target": "es2017",
    "jsx": "react",
    "typeRoots": [
      "node_modules/@types",
      "src/app/typings"
    ],
    "types": [
      "jest"
    ],
    "resolveJsonModule": true
  },
  "compileOnSave": false
}
