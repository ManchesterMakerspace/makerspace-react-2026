{
  "presets": [
    ["@babel/preset-env", {
      "targets": { "browsers": [">0.25%", "not dead"] },
      "useBuiltIns": false
    }],
    "@babel/preset-typescript",
    "@babel/preset-react"
  ],
  "plugins": [
    ["@babel/plugin-transform-typescript", { "allowNamespaces": true }],
    "inline-react-svg"
  ]
}
