{
  "name": "makerspace-react",
  "version": "0.1.1",
  "license": "MIT",
  "description": "React UI for the makerspace interface",
  "main": "index.js",
  "dependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@redux-devtools/extension": "^4.0.0",
    "awesome-debounce-promise": "^2.1.0",
    "axios": "^1.18.1",
    "braintree-web": "^3.143.0",
    "lodash-es": "^4.17.21",
    "makerspace-ts-api-client": "2.9.0",
    "moment-timezone": "^0.6.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.3.0",
    "react-router-dom": "^6.30.4",
    "react-select": "^5.10.2",
    "react-signature-canvas": "^1.0.7",
    "recharts": "^2.15.4",
    "redux": "^5.0.1",
    "redux-thunk": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/plugin-transform-typescript": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@playwright/test": "^1.61.1",
    "cross-env": "^10.1.0",
    "@types/braintree-web": "^3.96.0",
    "@types/jest": "^30.0.0",
    "@types/lodash-es": "^4.17.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "babel-loader": "^10.1.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.0.0",
    "html-loader": "^5.0.0",
    "html-webpack-plugin": "^5.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "mini-css-extract-plugin": "^2.0.0",
    "redux-mock-store": "^1.5.3",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "simple-git": "^3.5.0",
    "ts-jest": "^29.0.0",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsconfig-paths-webpack-plugin": "^4.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.108.4",
    "webpack-bundle-analyzer": "^5.0.0",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "^6.0.0"
  },
  "scripts": {
    "clean": "rm -fr ./node_modules ./dist",
    "start": "webpack serve --config dev.config.js",
    "open": "yarn start --open",
    "build": "cross-env NODE_ENV=production webpack --config prod.config.js && node scripts/build_rails_manifest.js",
    "test": "jest --no-cache",
    "test-watch": "yarn test --watch"
  },
  "jest": {
    "collectCoverage": false,
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}"
    ],
    "coverageReporters": [
      "text",
      "html"
    ],
    "transform": {
      "^.+\\.(j|t)sx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    },
    "testRegex": "/tests/unit/.*\\.spec\\.(j|t)sx?$",
    "moduleNameMapper": {
      "^(api|app|ui|documents)[/](.*)$": "<rootDir>/src/$1/$2"
    },
    "moduleFileExtensions": [
      "js",
      "ts",
      "tsx"
    ],
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {}
  }
}
